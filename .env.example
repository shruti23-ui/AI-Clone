# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── TTS: pick one ─────────────────────────────────────────────────────────────

# Option 1 — Google Cloud TTS (recommended: gives word timestamps → best lip sync)
# Get key: console.cloud.google.com → APIs → Cloud Text-to-Speech API → Credentials
GOOGLE_TTS_API_KEY=

# Option 2 — ElevenLabs (used by /api/tts endpoint for standalone TTS calls)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Vector DB (optional — defaults to in-memory) ──────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=shruti-portfolio
PINECONE_ENVIRONMENT=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
